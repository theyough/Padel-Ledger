{
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.3",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "api-platform/core": "^4.3",
    "doctrine/dbal": "^4.0",
    "doctrine/doctrine-bundle": "^2.12",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "doctrine/orm": "^3.2",
    "lexik/jwt-authentication-bundle": "^3.2",
    "symfony/console": "^7.0",
    "symfony/dotenv": "^7.0",
    "symfony/flex": "^2.4",
    "symfony/framework-bundle": "^7.0",
    "symfony/mailer": "^7.0",
    "symfony/mime": "^7.0",
    "symfony/password-hasher": "^7.0",
    "symfony/runtime": "^7.0",
    "symfony/security-bundle": "^7.0",
    "symfony/serializer": "^7.0",
    "symfony/validator": "^7.0",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "symfony/phpunit-bridge": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "test": "simple-phpunit",
    "cs-fix": "php-cs-fixer fix",
    "cs-fixer:check": "php-cs-fixer fix --dry-run --diff --verbose",
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  }
}
